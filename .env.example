# === NoneBot2 ===
DRIVER=~fastapi

# === OneBot v11 适配器 ===
ONEBOT_V11_ACCESS_TOKEN=

# === LLM Provider ===
LLM_PROVIDER=longcat
LONGCAT_MODEL=LongCat-Flash-Omni-2603
# DeepSeek 配置（LLM_PROVIDER=deepseek 时需要）
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# === Bot identity ===
BOT_QQ=
BOT_NAME=小y

# === 管理员 ===
SUPERUSERS=[]

# === LLM 输出限制 ===
MAX_RESPONSE_TOKENS=300

# === Agent 配置 ===
AGENT_MAX_ITER=3
AGENT_MAX_TOKENS=1024
AGENT_TOOL_TIMEOUT=15

# === 对话历史 ===
HISTORY_BACKEND=json
HISTORY_DIR=data/chats
GROUP_HISTORY_MAX_TURNS=300
USER_HISTORY_MAX_TURNS=15

# === 联网搜索 ===
ENABLE_WEB_SEARCH=true

# === 天气 ===
WEATHER_CITY=上海
WEATHER_LAT=31.2304
WEATHER_LON=121.4737

# === 广播 ===
BROADCAST_SCHEDULE=8:00,12:00,18:00
BROADCAST_CONTENT_TYPES=news,weather,custom

# === 调试 ===
DEBUG_MODE=false
